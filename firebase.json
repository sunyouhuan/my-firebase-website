{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/app",
        "function": "serveDashboard"
      },
      {
        "source": "/app/**",
        "function": "serveDashboard"
      },
      {
        "source": "/api/session-login",
        "function": "sessionLogin"
      },
      {
        "source": "/api/session-logout",
        "function": "sessionLogout"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "storage": {
    "rules": "storage.rules"
  }
}
